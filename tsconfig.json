{
  "compilerOptions": {
    // 输出的目录
    "outDir": "dist",
    // 采用 sourcemap
    "sourceMap": true,
    // 目标语法
    "target": "es2016",
    // 模块格式
    "module": "nodenext",
    // 模块解析方式
    "moduleResolution": "nodenext",
    // 严格模式
    "strict": false,
    // 解析 json 模块
    "resolveJsonModule": true,
    // 允许通过 es6 语法引入 commonjs 模块
    "esModuleInterop": true,
    // jsx 不转义
    "jsx": "preserve",
    // 支持的类库 — esnext 及 dom
    "lib": [
      "esnext",
      "dom"
    ],
    "paths": {
      "@vue/*": [
        "./packages/*/src"
      ]
    }
  }
}